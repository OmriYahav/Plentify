# Supabase auth/live data for Expo and React Native.
# Expo only exposes client-side variables prefixed with EXPO_PUBLIC_.
# Restart Expo after changing these values. Do not commit real keys.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_DEMO_CITY=Kfar Saba
# Phase 2 if moving maps provider outside Expo Go:
EXPO_PUBLIC_MAPBOX_TOKEN=
